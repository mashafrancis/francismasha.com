    "libphonenumber-js": "^1.13.7",
    "lucide-react": "^1.21.0",
    "motion": "^12.40.0",
    "next": "^16.2.9",
    "next-axiom": "^1.10.0",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "next-view-transitions": "^0.3.5",
    "radix-ui": "^1.6.0",
