    "@tailwindcss/typography": "^0.5.20",
    "@types/bun": "latest",
    "@types/node": "^26.0.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "gray-matter": "^4.0.3",
