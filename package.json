    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mashafrancis/francismasha.com.git"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "preview": "next build && next start",
    "check": "biome check .",
    "check:unsafe": "biome check --write --unsafe .",
    "check:write": "biome check --write .",
    "check-types": "tsc --noEmit --pretty",
    "registry:internal:build": "tsx --tsconfig ./tsconfig.scripts.json ./src/scripts/build-registry.mts",
    "registry:build": "bun run registry:internal:build && shadcn build ./src/__registry__/registry.autogenerated.json",
    "capture": "tsx --tsconfig ./tsconfig.scripts.json ./src/scripts/capture.mts",
    "generate:icons": "bun ./src/scripts/generate-icons.js",
    "generate-libphonenumber-metadata": "libphonenumber-metadata-generator ./src/assets/libphonenumber.metadata.json --countries VN --extended",
    "upgrade:next": "npx @next/codemod@latest upgrade latest",
    "upgrade:tailwind": "npx @tailwindcss/upgrade@latest",
    "prepare": "husky",
    "update": "pnpm dlx taze -r -I patch"
  },
  "dependencies": {
    "@bklit/sdk": "^1.0.1",
    "@bprogress/next": "^3.2.12",
    "@embrace-io/web-sdk": "^2.14.0",
    "@hookform/resolvers": "^5.2.2",
    "@microsoft/clarity": "^1.0.2",
    "@ncdai/react-wheel-picker": "^1.2.0",
    "@newrelic/browser-agent": "^1.310.1",
    "@openpanel/nextjs": "^1.3.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.213.0",
    "@opentelemetry/sdk-logs": "^0.213.0",
    "@vercel/analytics": "^2.0.0",
    "@vercel/otel": "^2.1.1",
    "@vercel/speed-insights": "^2.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "botid": "^1.5.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dayjs": "^1.11.19",
    "fumadocs-core": "^16.6.14",
    "jotai": "^2.18.1",
    "libphonenumber-js": "^1.12.39",
    "lucide-react": "^0.577.0",
    "motion": "^12.34.5",
    "next": "^16.1.6",
    "next-axiom": "^1.10.0",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "next-view-transitions": "^0.3.5",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-confetti": "^6.4.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-markdown": "^10.1.0",
    "react-use": "^17.6.0",
    "schema-dts": "^1.1.5",
    "shadcn": "^4.0.3",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "vcard-creator": "^0.7.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.3.5",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "libphonenumber-metadata-generator": "^2.0.4",
    "lint-staged": "^16.3.3",
    "puppeteer-core": "^24.39.0",
    "rehype-external-links": "^3.0.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "rimraf": "^6.1.3",
    "shiki": "^4.0.2",
    "strip-indent": "^4.1.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "ultracite": "^7.2.5",
    "unist-builder": "^4.0.0",
    "unist-util-visit": "^5.1.0"
  },
  "private": true,
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "npx ultracite format"
    ]
  },
  "packageManager": "pnpm@10.32.1"
}
